# ============================================
# BRIDGE AFRIKA PORTFOLIO - Configuration
# ============================================
# Copiez ce fichier en .env et personnalisez les valeurs
# Ne JAMAIS committer le fichier .env réel !

# ============================================
# BASE DE DONNÉES
# ============================================

# Développement local (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./bridge_portfolio.db

# Production (PostgreSQL) - Décommentez pour Render
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/bridge_portfolio

# ============================================
# SÉCURITÉ - JWT
# ============================================

# Générez une clé secrète forte avec : openssl rand -hex 32
SECRET_KEY=votre-cle-secrete-tres-longue-et-aleatoire-ici-minimum-32-caracteres

# Algorithme de signature JWT (HS256 recommandé)
JWT_ALGORITHM=HS256

# Durée de validité du token d'accès en minutes (8 heures par défaut)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ============================================
# API INTERNES
# ============================================

# Clé API pour sécuriser les communications avec BridgeHub
INTERNAL_API_KEY=bridgehub-secret-key-change-me-in-production

# ============================================
# ENVIRONNEMENT
# ============================================

# Mettre "true" en production sur Render, laisser vide en local
RENDER=

# URL externe sur Render (optionnel)
RENDER_EXTERNAL_URL=

# ============================================
# ENVOI D'EMAILS (fonctionnalité future)
# ============================================

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre-email@gmail.com
# SMTP_PASSWORD=votre-mot-de-passe-app
# EMAIL_FROM=contact@bridgeafrika.com

# ============================================
# SERVICES EXTERNES (fonctionnalités futures)
# ============================================

# WhatsApp Cloud API
# WHATSAPP_API_KEY=
# WHATSAPP_PHONE_ID=

# Africa's Talking (SMS)
# AT_API_KEY=
# AT_USERNAME=

# Redis (cache)
# REDIS_URL=redis://localhost:6379/0